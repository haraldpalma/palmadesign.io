---
import '../styles/global.css';
import Seo from '../components/Seo.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ConsentBanner from '../components/ConsentBanner.astro';
import Promo from '../components/Promo.astro';
import { OG_IMAGE, SITE_NAME } from '../lib/site';

interface Props {
  title: string;
  description: string;
  path: string;
  ogImage?: string;
  noindex?: boolean;
  jsonLd?: object;
  type?: 'website' | 'article';
  preloadImage?: string; // LCP image to preload (fetchpriority high)
}
const {
  title,
  description,
  path,
  ogImage = OG_IMAGE,
  noindex = false,
  jsonLd,
  type = 'website',
  preloadImage,
} = Astro.props;
---
<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#f1f0f0" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- No-flash theme: resolve persisted theme before first paint (default light). -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('pd-theme');
          if (t !== 'light' && t !== 'dark') t = 'light';
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>

    <!-- Self-hosted display serif (Playfair Display); the sans is a system stack. -->
    <link rel="preload" href="/fonts/PlayfairDisplay-latin.woff2" as="font" type="font/woff2" crossorigin />
    {
      preloadImage && (
        <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />
      )
    }

    <Seo
      title={title}
      description={description}
      path={path}
      ogImage={ogImage}
      noindex={noindex}
      jsonLd={jsonLd}
      type={type}
    />
  </head>
  <body>
    <a href="#main" class="visually-hidden">Skip to content</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <ConsentBanner />
    <Promo />
  </body>
</html>
