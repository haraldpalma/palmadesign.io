---
// Official Palma Design logo (inline SVG → follows currentColor across sections).
// wordmark = full logo (mark + "palmadesign"); mark = the glyph only.
import { brand } from '../../brand.config';
import full from './logo-full.svg?raw';
import mark from './logo-mark.svg?raw';

interface Props {
  variant?: 'wordmark' | 'mark';
  height?: number;
  class?: string;
}
const { variant = 'wordmark', height = 26, class: klass } = Astro.props;
const svg = variant === 'mark' ? mark : full;
---
<span
  class:list={['logo', klass]}
  style={`--logo-h:${height}px`}
  role="img"
  aria-label={brand.name}
  set:html={svg}
/>

<style>
  .logo {
    display: inline-flex;
    color: inherit;
  }
  .logo :global(svg) {
    height: var(--logo-h);
    width: auto;
    display: block;
  }
</style>
