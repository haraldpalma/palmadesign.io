---
import Logo from './Logo.astro';
import { org, brand } from '../lib/site';
const year = new Date().getFullYear();
---
<footer class="bleed footer2" data-sec="dark">
  <div class="wrap-wide">
    <div class="footer2-top">
      <div>
        <div class="footer2-brand"><Logo variant="wordmark" height={26} /></div>
        <p class="footer2-tag">
          Palma Design is a Vienna-based design &amp; no-code studio helping businesses build
          portals, tools and websites — and keep them running.
        </p>
      </div>
      <div class="footer2-col">
        <div class="h">Contact</div>
        <a href={`mailto:${org.email}`}>{org.email}</a>
      </div>
      <div class="footer2-col">
        <div class="h">Location</div>
        <span>Vienna, Austria</span>
      </div>
    </div>
    <div class="footer2-bar">
      <div>© {year} {brand.name}. All rights reserved.</div>
      <div class="links">
        <a href="/impressum">Impressum</a>
        <a href="/privacy">Privacy</a>
        <a href="/terms">Terms</a>
      </div>
    </div>
  </div>
</footer>
