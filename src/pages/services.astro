---
import BaseLayout from '../layouts/BaseLayout.astro';
import Faq from '../components/Faq.astro';
import { site, meta, brand, SITE_URL } from '../lib/site';
import { graph, webPageNode, breadcrumbNode, faqNode } from '../lib/schema';
import showcase from '../content/settings/services-showcase.json';

const s = site.services;
const m = meta.services;
const head = s.headline.split(s.headlineEmphasis);

// Project screenshots for the showcase (editable in Keystatic: Singletons →
// "Services — showcase images"). Normalise so a bare Keystatic filename and a
// full public path both resolve. Three cards; each gets a fan preset — the
// clustered offset/rotation it animates FROM as you scroll (see .showcase CSS).
const FAN = [
  { cx: '250px', cy: '18px', rot: '-10deg', z: 2 },
  { cx: '0px', cy: '-10px', rot: '4deg', z: 3 },
  { cx: '-250px', cy: '22px', rot: '10deg', z: 1 },
];
const shots = (showcase.images ?? [])
  .filter((i: { src?: string }) => i && i.src)
  .slice(0, 3)
  .map((i: { src: string; alt?: string }, idx: number) => ({
    src: /^(https?:)?\//.test(i.src) ? i.src : `/images/showcase/${i.src}`,
    alt: i.alt ?? '',
    ...FAN[idx],
  }));

const service = {
  '@type': 'Service',
  name: 'Design studio services',
  provider: { '@id': `${SITE_URL}/#org` },
  areaServed: 'Worldwide',
  description: s.intro,
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Services',
    itemListElement: s.offerings.map((o: { title: string; body: string }) => ({
      '@type': 'Offer',
      itemOffered: { '@type': 'Service', name: o.title, description: o.body },
    })),
  },
};
const jsonLd = graph(
  webPageNode({ url: `${SITE_URL}/services`, name: m.title, description: m.description }),
  breadcrumbNode([
    { name: 'Home', url: `${SITE_URL}/` },
    { name: 'Services', url: `${SITE_URL}/services` },
  ]),
  service,
  faqNode(site.faqs)
);
---
<BaseLayout title={m.title} description={m.description} path="/services" jsonLd={jsonLd}>
  <div class="page-intro">
    <div class="wrap">
      <p class="eyebrow">{s.eyebrow}</p>
      <h1 class="page-head">{head[0]}<em class="headline-em">{s.headlineEmphasis}</em>{head[1]}</h1>
      <p class="page-lead">{s.intro}</p>
      <div class="page-cta"><a class="btn-yellow" href="/contact">{brand.cta} →</a></div>
    </div>
  </div>

  <section class="section" style="padding:80px 0">
    <div class="wrap">
      {
        shots.length > 0 && (
          <div class="showcase" data-showcase aria-label="Selected project screenshots">
            <div class="showcase-row">
              {shots.map((shot) => (
                <figure
                  class="showcase-item"
                  style={`--cx:${shot.cx};--cy:${shot.cy};--rot:${shot.rot};z-index:${shot.z}`}
                >
                  <img src={shot.src} alt={shot.alt} loading="lazy" width="800" height="500" />
                </figure>
              ))}
            </div>
          </div>
        )
      }
      <div class="block-list">
        {
          s.offerings.map((o: { title: string; body: string; more?: string }) => (
            <div>
              <h3>{o.title}</h3>
              <p>{o.body}</p>
              {o.more && (
                <details class="readmore">
                  <summary>Read more</summary>
                  <p>{o.more}</p>
                </details>
              )}
            </div>
          ))
        }
      </div>
      <div style="max-width:640px;margin-top:36px">
        {s.notes.map((n: string) => <p class="prose-note">{n}</p>)}
      </div>
      <div class="mt-cta">
        <a class="btn-primary" href="/contact">{brand.cta}</a>
      </div>
    </div>
  </section>

  <Faq />
</BaseLayout>

<script>
  // Scrubbed cluster → stretch. --t (0..1) is driven by scroll: at 0 the three
  // screenshots sit as a fanned, overlapping deck; at 1 they've straightened
  // into a spaced row. Scrolling back up re-clusters them. The per-card offset
  // and rotation live in inline --cx/--cy/--rot; the CSS lerps them by (1 - t).
  // No-JS = the resting row (t defaults to 0 → fanned, still legible);
  // reduced-motion = pinned to the spread row.
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const el = document.querySelector<HTMLElement>('[data-showcase]');
  if (el) {
    if (reduce) {
      el.style.setProperty('--t', '1');
    } else {
      let startScroll = 0;
      let range = 380;
      const measure = () => {
        const vh = window.innerHeight;
        const docTop = el.getBoundingClientRect().top + window.scrollY;
        // Start clustered when the deck is first on screen, finish within ~half
        // a viewport of scrolling.
        startScroll = Math.max(0, docTop - vh * 0.8);
        range = Math.max(280, Math.min(460, vh * 0.55));
      };
      let ticking = false;
      const update = () => {
        const t = Math.min(1, Math.max(0, (window.scrollY - startScroll) / range));
        el.style.setProperty('--t', String(t));
        ticking = false;
      };
      const onScroll = () => {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(update);
        }
      };
      measure();
      update();
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', () => {
        measure();
        update();
      }, { passive: true });
    }
  }

  // Mobile (stacked cards): gentle micro-reveal as each scrolls into view.
  // No-op visually on desktop (the .revealed styles only exist below 900px).
  const cards = document.querySelectorAll<HTMLElement>('.showcase-item');
  if (cards.length && !reduce && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('revealed');
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.18, rootMargin: '0px 0px -6% 0px' }
    );
    cards.forEach((c) => io.observe(c));
  }
</script>
