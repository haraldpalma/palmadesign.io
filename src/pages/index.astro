---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, meta, brand, SITE_URL, SITE_NAME } from '../lib/site';
import { graph, webPageNode, breadcrumbNode, faqNode } from '../lib/schema';

const h = site.home;
const faqs = site.faqs as { q: string; a: string }[];
const m = meta.home;

// Selected work pulls from the real case-study collection so the home never drifts.
const selected = (await getCollection('work', ({ data }) => !data.draft))
  .sort((a, b) => (a.data.year < b.data.year ? 1 : -1))
  .slice(0, 3);

function splitEmphasis(text: string, word: string) {
  const i = text.indexOf(word);
  if (i === -1) return { before: text, word: '', after: '' };
  return { before: text.slice(0, i), word, after: text.slice(i + word.length) };
}
const head = splitEmphasis(h.headline, h.headlineEmphasis);
const quote = splitEmphasis(h.quote, h.quoteEmphasis);

const jsonLd = graph(
  webPageNode({ url: `${SITE_URL}/`, name: m.title, description: h.headline, about: true }),
  breadcrumbNode([{ name: 'Home', url: `${SITE_URL}/` }]),
  faqNode(faqs)
);
---
<BaseLayout title={m.title} description={m.description} path="/" jsonLd={jsonLd}>
  <!-- Hero -->
  <header class="hero-header">
    <div class="wrap">
      <div class="hero">
        <div>
          <p class="eyebrow">{h.eyebrow}</p>
          <h1>
            {head.before}<em class="headline-em">{head.word}</em>{head.after}
          </h1>
          <p class="hero-sub">{h.subline}</p>
          <div class="hero-actions">
            <a class="btn-primary" href="/contact">{h.ctaPrimary}</a>
            <a class="btn-ghost" href="/work"><span>{h.ctaGhost}</span></a>
          </div>
        </div>
        <div class="portrait">
          <img src="/img/portrait.svg" alt="Palma Design" width="640" height="800" fetchpriority="high" />
          <div class="portrait-caption">{h.portraitCaption}</div>
        </div>
      </div>
    </div>
  </header>

  <!-- Proof row -->
  <div class="proof-band">
    <div class="wrap">
      <div class="proof">
        {
          h.proof.map((p: { key: string; rest: string }) => (
            <div class="proof-item">
              <b>{p.key}</b> {p.rest}
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <!-- What we do -->
  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <h2 class="eyebrow">What we do</h2>
        <div class="serif-note">01 — 03</div>
      </div>
      {
        h.work.map((w: { n: string; title: string; body: string; action: string; page: string }) => (
          <a class="work-row" href={`/${w.page}`}>
            <div class="work-num">{w.n}</div>
            <div>
              <h3>{w.title}</h3>
              <p>{w.body}</p>
            </div>
            <div class="work-go">{w.action} →</div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Selected work -->
  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <h2 class="eyebrow">Selected work</h2>
        <a class="serif-note" href="/work">All work →</a>
      </div>
      <div class="grid3">
        {
          selected.map((cs) => (
            <a class="post-card" href={`/work/${cs.id}`}>
              <div class="post-cat">{cs.data.category}</div>
              <h3>{cs.data.title}</h3>
              <div class="post-meta">
                {cs.data.client} · {cs.data.industry} · {cs.data.year}
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="wrap">
      <div class="section-head" style="margin-bottom:44px">
        <h2 class="eyebrow">Questions</h2>
        <div class="serif-note">Straight answers</div>
      </div>
      <div class="faq">
        {
          faqs.map((f) => (
            <details>
              <summary>
                <span>{f.q}</span>
                <span class="plus">+</span>
              </summary>
              <p>{f.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Quote band -->
  <section class="quote-band">
    <div class="wrap">
      <blockquote class="quote">
        {quote.before}<em>{quote.word}</em>{quote.after}
      </blockquote>
      <div class="quote-sig">— {SITE_NAME}</div>
    </div>
  </section>
</BaseLayout>
