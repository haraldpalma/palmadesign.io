---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Faq from '../components/Faq.astro';
import { site, meta, SITE_URL } from '../lib/site';
import { graph, webPageNode, breadcrumbNode } from '../lib/schema';

const m = meta.home;
const proof = site.home.proof as { key: string; rest: string }[];

const work = (await getCollection('work', ({ data }) => !data.draft)).sort((a, b) =>
  a.data.year < b.data.year ? 1 : -1
);

// Latest gallery pieces for the home teaser strip.
const graphics = (await getCollection('graphics', ({ data }) => !data.draft))
  .sort((a, b) => (a.data.year < b.data.year ? 1 : -1))
  .slice(0, 3);
const gSrc = (img: string) => (/^(https?:)?\//.test(img) ? img : `/images/graphics/${img}`);

const expertise = [
  { title: 'Brand & identity', body: 'Logos, marks and full identity systems — one clear idea, held with discipline, applied everywhere.' },
  { title: 'Print & campaign', body: 'Editorial, packaging and campaign graphics that still have to survive a press check — twenty-five years of them.' },
  { title: 'Websites, written in code', body: 'Fast static sites designed in the studio and hand-coded with Claude — like this one — engineered to be found by Google and quoted by AI assistants.' },
  { title: 'AI-assisted craft', body: 'The machines handle production; the studio keeps the taste. Every tool in the box, judgment always human.' },
];

const jsonLd = graph(
  webPageNode({ url: `${SITE_URL}/`, name: m.title, description: m.description, about: true }),
  breadcrumbNode([{ name: 'Home', url: `${SITE_URL}/` }])
);
---
<BaseLayout title={m.title} description={m.description} path="/" jsonLd={jsonLd}>
  <!-- HERO (dark) -->
  <header class="bleed hero-xl" data-sec="dark">
    <div class="wrap-wide">
      <p class="hero-eyebrow">European Design Studio — working everywhere</p>
      <h1 class="hero-title">Twenty-five years of craft. <span class="accent">Zero templates</span></h1>
      <div class="hero-actions">
        <a class="btn-yellow" href="/work">View our work</a>
        <a class="btn-outline" href="/contact">Start a project →</a>
      </div>
    </div>
  </header>

  <!-- PROOF -->
  <div class="bleed">
    <div class="wrap-wide" style="display:flex;justify-content:space-between;flex-wrap:wrap;gap:16px 40px;padding:32px 0;border-bottom:1px solid var(--line)">
      {
        proof.map((p) => (
          <div style="font-size:clamp(15px,1.6vw,22px);color:var(--muted)">
            <b style="color:var(--text);font-weight:700">{p.key}</b> {p.rest}
          </div>
        ))
      }
    </div>
  </div>

  <!-- THE STUDIO -->
  <section class="bleed agency">
    <div class="wrap-wide">
      <p class="agency-eyebrow">The Studio</p>
      <p class="agency-lead">
        Palma Design is a European design studio, at home everywhere —
        <span class="muted">graphic design since the late nineties, and websites designed in the studio and written in code with AI. No templates, no page builders, nothing off the rack.</span>
      </p>
    </div>
  </section>

  <!-- OUR WORK -->
  <section class="bleed workwrap">
    <div class="wrap-wide">
      <div class="work-head">
        <div class="label">Our Work</div>
        <p class="title">Crafted with <span class="on">structure</span>, <span class="on">clarity</span>, and purpose.</p>
      </div>
      {
        work.map((cs, i) => (
          <div class:list={['workrow', { rev: i % 2 === 1 }]}>
            <a class="work-media" href={`/work/${cs.id}`} aria-label={cs.data.title}>
              Add a screenshot — {cs.data.client}
            </a>
            <div>
              <div class="work-num">{String(i + 1).padStart(2, '0')}</div>
              <h3 class="work-title">{cs.data.client}</h3>
              <div class="work-cat">{cs.data.category} · {cs.data.industry}</div>
              <p class="work-body">{cs.data.excerpt}</p>
              <a class="work-link" href={`/work/${cs.id}`}>View project →</a>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- EXPERTISE (dark) -->
  <section class="bleed expertise" data-sec="dark">
    <div class="wrap-wide">
      <h2 class="expertise-h">Expertise</h2>
      {
        expertise.map((e) => (
          <div class="exp-item">
            <h3 class="exp-title">{e.title}</h3>
            <p class="exp-desc">{e.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- GRAPHICS TEASER -->
  <section class="bleed workwrap" style="border-top:1px solid var(--line)">
    <div class="wrap-wide">
      <div class="work-head">
        <div class="label">Graphics</div>
        <p class="title">Twenty-five years on <span class="on">paper</span> and <span class="on">pixels</span>.</p>
      </div>
      <div class="home-gallery">
        {
          graphics.map((g) => (
            <a class="home-gallery-item" href="/graphics" aria-label={`${g.data.title} — see all graphics`}>
              <img src={gSrc(g.data.image)} alt={g.data.alt} loading="lazy" width="800" height="1000" />
              <span class="home-gallery-cap">{g.data.category} · {g.data.year}</span>
            </a>
          ))
        }
      </div>
      <div class="mt-cta">
        <a class="work-link" href="/graphics">Browse the gallery →</a>
      </div>
    </div>
  </section>

  <style>
    .home-gallery {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--gutter);
    }
    @media (max-width: 720px) {
      .home-gallery {
        grid-template-columns: 1fr;
        gap: 28px;
      }
    }
    .home-gallery-item {
      display: block;
      text-decoration: none;
    }
    .home-gallery-item img {
      display: block;
      width: 100%;
      height: auto;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--ink);
    }
    .home-gallery-cap {
      display: block;
      margin-top: 10px;
      font-size: 13px;
      color: var(--muted);
    }
  </style>

  <!-- CTA (yellow) -->
  <section class="bleed cta-band" data-sec="yellow">
    <div class="wrap-wide">
      <h2>Want to start a project with us?</h2>
      <a class="btn-dark" href="/contact">Get in touch →</a>
    </div>
  </section>

  <Faq />
</BaseLayout>
