---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, meta, SITE_URL } from '../lib/site';
import { graph, webPageNode, breadcrumbNode } from '../lib/schema';

const m = meta.home;
const proof = site.home.proof as { key: string; rest: string }[];

const work = (await getCollection('work', ({ data }) => !data.draft)).sort((a, b) =>
  a.data.year < b.data.year ? 1 : -1
);

const expertise = [
  { title: 'Client portals & apps', body: 'Authenticated portals, marketplaces and member sites on Softr and Airtable — roles and permissions solved once and kept solved.' },
  { title: 'Internal tools', body: 'The app that replaces the spreadsheet: ordering systems, intranets, project trackers, knowledge bases. Fast to ship, easy to change.' },
  { title: 'Custom websites', body: 'Fast static sites built with Claude — like this one — engineered to be found by Google and quoted by AI assistants.' },
  { title: 'AI & automation', body: 'Make, REST APIs and AI wired into your workflow to remove the steps nobody enjoys — measured against real outcomes.' },
];

const jsonLd = graph(
  webPageNode({ url: `${SITE_URL}/`, name: m.title, description: m.description, about: true }),
  breadcrumbNode([{ name: 'Home', url: `${SITE_URL}/` }])
);
---
<BaseLayout title={m.title} description={m.description} path="/" jsonLd={jsonLd}>
  <!-- HERO (dark) -->
  <header class="bleed hero-xl" data-sec="dark">
    <div class="wrap-wide">
      <p class="hero-eyebrow">Design &amp; no-code Studio — Vienna</p>
      <h1 class="hero-title">Software your team will <span class="accent">actually use</span></h1>
      <div class="hero-actions">
        <a class="btn-yellow" href="/work">View our work</a>
        <a class="btn-outline" href="/contact">Start a project →</a>
      </div>
    </div>
  </header>

  <!-- PROOF -->
  <div class="bleed">
    <div class="wrap-wide" style="display:flex;justify-content:space-between;flex-wrap:wrap;gap:16px 40px;padding:32px 0;border-bottom:1px solid var(--line)">
      {
        proof.map((p) => (
          <div style="font-size:clamp(15px,1.6vw,22px);color:var(--muted)">
            <b style="color:var(--text);font-weight:700">{p.key}</b> {p.rest}
          </div>
        ))
      }
    </div>
  </div>

  <!-- THE STUDIO -->
  <section class="bleed agency">
    <div class="wrap-wide">
      <p class="agency-eyebrow">The Studio</p>
      <p class="agency-lead">
        Palma Design is a Vienna-based design &amp; no-code studio —
        <span class="muted">we build client portals, internal tools and custom websites on Softr, Airtable and Claude, and keep them running for years.</span>
      </p>
    </div>
  </section>

  <!-- OUR WORK -->
  <section class="bleed workwrap">
    <div class="wrap-wide">
      <div class="work-head">
        <div class="label">Our Work</div>
        <p class="title">Crafted with <span class="on">structure</span>, <span class="on">clarity</span>, and purpose.</p>
      </div>
      {
        work.map((cs, i) => (
          <div class:list={['workrow', { rev: i % 2 === 1 }]}>
            <a class="work-media" href={`/work/${cs.id}`} aria-label={cs.data.title}>
              Add a screenshot — {cs.data.client}
            </a>
            <div>
              <div class="work-num">{String(i + 1).padStart(2, '0')}</div>
              <h3 class="work-title">{cs.data.client}</h3>
              <div class="work-cat">{cs.data.category} · {cs.data.industry}</div>
              <p class="work-body">{cs.data.excerpt}</p>
              <a class="work-link" href={`/work/${cs.id}`}>View project →</a>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- EXPERTISE (dark) -->
  <section class="bleed expertise" data-sec="dark">
    <div class="wrap-wide">
      <h2 class="expertise-h">Expertise</h2>
      {
        expertise.map((e) => (
          <div class="exp-item">
            <h3 class="exp-title">{e.title}</h3>
            <p class="exp-desc">{e.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- TESTIMONIAL -->
  <section class="bleed testimonial">
    <div class="wrap-wide">
      <p class="t-eyebrow">What our clients say</p>
      <blockquote>
        "A huge improvement over what we had before — much more efficient. The combination of
        personalized budgets, dashboards and admin controls was exactly what we needed."
      </blockquote>
      <div class="t-who">
        <div class="t-avatar"></div>
        <div>
          <div class="t-name">Baumit team</div>
          <div class="t-role">Enterprise ordering system</div>
        </div>
      </div>
      <p class="t-note">Client feedback from the Baumit project — a named quote can replace this.</p>
    </div>
  </section>

  <!-- CTA (yellow) -->
  <section class="bleed cta-band" data-sec="yellow">
    <div class="wrap-wide">
      <h2>Want to start a project with us?</h2>
      <a class="btn-dark" href="/contact">Get in touch →</a>
    </div>
  </section>
</BaseLayout>
