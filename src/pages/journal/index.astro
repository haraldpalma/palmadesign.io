---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { meta, brand, SITE_URL } from '../../lib/site';
import { graph, webPageNode, breadcrumbNode } from '../../lib/schema';

const posts = (await getCollection('journal', ({ data }) => !data.draft)).sort((a, b) =>
  a.data.date < b.data.date ? 1 : -1
);

const cats = ['All', ...brand.journalCategories] as readonly string[];
const m = meta.journal;

const fmt = (d: string) =>
  new Date(d).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

const jsonLd = graph(
  webPageNode({ url: `${SITE_URL}/journal`, name: m.title, description: m.description }),
  breadcrumbNode([
    { name: 'Home', url: `${SITE_URL}/` },
    { name: 'Journal', url: `${SITE_URL}/journal` },
  ])
);
---
<BaseLayout title={m.title} description={m.description} path="/journal" jsonLd={jsonLd}>
  <div class="page-intro">
    <div class="wrap">
      <p class="eyebrow">Journal</p>
      <h1 class="page-head">Notes from the <em class="headline-em">studio</em>.</h1>
      <p class="page-lead">
        Writing on design, websites and AI — what changes when machines can produce, and why
        taste still decides.
      </p>
    </div>
  </div>

  <section class="section" style="padding:64px 0 92px;border-bottom:none">
    <div class="wrap">
      <div class="cat-filter" role="group" aria-label="Filter by category">
        {
          cats.map((c) => (
            <button
              type="button"
              class="cat-chip"
              data-cat-filter={c}
              aria-pressed={c === 'All' ? 'true' : 'false'}
            >
              {c}
            </button>
          ))
        }
      </div>

      <div class="grid3 writing-index" data-post-grid>
        {
          posts.map((p) => (
            <article class="post-item" data-cat={p.data.category}>
              <a class="post-card" href={`/journal/${p.id}`}>
                <div class="post-cat">{p.data.category}</div>
                <h3>{p.data.title}</h3>
                <p class="post-excerpt">{p.data.excerpt}</p>
                <div class="post-meta">Harald Palma · {fmt(p.data.date)}</div>
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const chips = document.querySelectorAll<HTMLButtonElement>('[data-cat-filter]');
  const items = document.querySelectorAll<HTMLElement>('.post-item');
  chips.forEach((chip) =>
    chip.addEventListener('click', () => {
      const cat = chip.getAttribute('data-cat-filter');
      chips.forEach((c) => c.setAttribute('aria-pressed', String(c === chip)));
      items.forEach((item) => {
        const show = cat === 'All' || item.getAttribute('data-cat') === cat;
        item.style.display = show ? '' : 'none';
      });
    })
  );
</script>
