# Keystatic (GitHub storage mode) — required for the /keystatic admin to work.
# These are SECRETS: set them in the Netlify site env (and a local .env for dev),
# never commit real values. The easiest way to obtain them is the guided flow:
# run `npm run dev`, open http://localhost:4322/keystatic, and click
# "Set up Keystatic with GitHub" — it creates the GitHub App and fills these in.
#
# Then add the SAME three variables to the Netlify site (palmadesign.io) and
# add the production OAuth callback URL to the GitHub App:
#   https://palmadesign.io/api/keystatic/github/oauth/callback

KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=
